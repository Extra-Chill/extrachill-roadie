{
  "url": "/",
  "profile": "mobile-chrome",
  "captures": ["steps", "console", "errors", "html", "network", "screenshot", "dom-snapshot"],
  "steps": [
    {"kind": "expect", "selector": "body", "state": "visible"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "detached"},
    {"kind": "navigate", "url": "/artist/", "waitFor": "load"},
    {"kind": "expect", "selector": "body", "state": "visible"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/artist/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "detached"},
    {"kind": "navigate", "url": "/events/", "waitFor": "load"},
    {"kind": "expect", "selector": "body", "state": "visible"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/events/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "detached"},
    {"kind": "navigate", "url": "/community/", "waitFor": "load"},
    {"kind": "expect", "selector": "body", "state": "visible"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/community/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "detached"}
  ],
  "assertions": [{"type": "noPageErrors"}]
}
