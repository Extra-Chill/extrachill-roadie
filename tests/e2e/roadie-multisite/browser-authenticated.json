{
  "url": "/",
  "auth": "wordpress-admin",
  "authUserId": 2,
  "profile": "desktop-chrome",
  "captures": ["steps", "console", "errors", "html", "network", "screenshot", "dom-snapshot"],
  "steps": [
    {"kind": "expect", "selector": "body", "state": "visible"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "attached"},
    {"kind": "click", "selector": ".frontend-agent-chat__fab"},
    {"kind": "expect", "selector": ".frontend-agent-chat__drawer.is-open", "state": "visible"},
    {"kind": "fill", "selector": ".agenttic-embedded__input textarea", "value": "First deterministic Roadie message."},
    {"kind": "click", "selector": ".agenttic-embedded__input button[aria-label=\"Send message\"]"},
    {"kind": "waitFor", "selector": "text=Deterministic Roadie initial reply.", "timeout": "20s"},
    {"kind": "expect", "selector": "text=Deterministic Roadie initial reply.", "state": "visible"},
    {"kind": "navigate", "url": "/artist/", "waitFor": "load"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/artist/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "attached"},
    {"kind": "click", "selector": ".frontend-agent-chat__fab"},
    {"kind": "expect", "selector": ".frontend-agent-chat__session-select", "state": "visible"},
    {"kind": "fill", "selector": ".agenttic-embedded__input textarea", "value": "Second deterministic Roadie message."},
    {"kind": "click", "selector": ".agenttic-embedded__input button[aria-label=\"Send message\"]"},
    {"kind": "waitFor", "selector": "text=Deterministic Roadie continuation reply.", "timeout": "20s"},
    {"kind": "expect", "selector": "text=Deterministic Roadie initial reply.", "state": "visible"},
    {"kind": "expect", "selector": "text=Deterministic Roadie continuation reply.", "state": "visible"},
    {"kind": "navigate", "url": "/events/", "waitFor": "load"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/events/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "attached"},
    {"kind": "navigate", "url": "/community/", "waitFor": "load"},
    {"kind": "expect", "selector": "link[rel=\"https://api.w.org/\"][href$=\"/community/wp-json/\"]", "state": "attached"},
    {"kind": "expect", "selector": "[data-frontend-agent-chat]", "state": "attached"}
  ],
  "assertions": [{"type": "noPageErrors"}]
}
